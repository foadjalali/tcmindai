# Zoho SMTP server host.
SMTP_HOST=smtp.zoho.com

# Zoho SMTP port. Use 587 with SMTP_SECURE=false for STARTTLS.
SMTP_PORT=587

# Set to false for Zoho STARTTLS on port 587. Set to true only for implicit TLS ports such as 465.
SMTP_SECURE=false

# Full Zoho mailbox address used for SMTP authentication and the From address.
SMTP_USER=

# Zoho mailbox password or Zoho App Password.
SMTP_PASS=

# Email address that receives internal contact form notifications.
CONTACT_RECEIVER=
